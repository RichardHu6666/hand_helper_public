# DSI panel selection (required by dsi_init component)
CONFIG_EXAMPLE_LCD_PATTERN_EK79007=y

# DSI resolution (1024x600 for EK79007)
CONFIG_EXAMPLE_MIPI_DSI_DISP_HRES_1024=y
CONFIG_EXAMPLE_MIPI_DSI_DISP_HRES=1024
CONFIG_EXAMPLE_MIPI_DSI_DISP_VRES_600=y
CONFIG_EXAMPLE_MIPI_DSI_DISP_VRES=600

# DMA2D acceleration for display
CONFIG_EXAMPLE_MIPI_DSI_DISP_USE_DMA2D=y

# PSRAM (required for frame buffers)
CONFIG_SPIRAM=y

# Experimental features (needed for some P4 peripherals)
CONFIG_IDF_EXPERIMENTAL_FEATURES=y

# Hosted Wi-Fi baseline for P4 + on-board C6
CONFIG_ESP_HOSTED_ENABLED=y
CONFIG_ESP_HOSTED_CP_TARGET_ESP32C6=y
CONFIG_ESP_HOSTED_IDF_SLAVE_TARGET="esp32c6"
CONFIG_ESP_HOSTED_SDIO_HOST_INTERFACE=y
CONFIG_ESP_HOSTED_SDIO_SLOT_1=y
CONFIG_ESP_HOSTED_SDIO_SLOT=1
CONFIG_ESP_HOSTED_SDIO_4_BIT_BUS=y
CONFIG_ESP_HOSTED_SDIO_BUS_WIDTH=4
CONFIG_ESP_HOSTED_SDIO_CLOCK_FREQ_KHZ=40000
CONFIG_ESP_HOSTED_SDIO_GPIO_RESET_SLAVE=54
CONFIG_ESP_HOSTED_SDIO_PIN_CMD=19
CONFIG_ESP_HOSTED_SDIO_PIN_CLK=18
CONFIG_ESP_HOSTED_SDIO_PIN_D0=14
CONFIG_ESP_HOSTED_SDIO_PIN_D1=15
CONFIG_ESP_HOSTED_SDIO_PIN_D2=16
CONFIG_ESP_HOSTED_SDIO_PIN_D3=17
CONFIG_ESP_HOSTED_SDIO_RESET_DELAY_MS=1500
CONFIG_ESP_HOSTED_SLAVE_RESET_ON_EVERY_HOST_BOOTUP=y
CONFIG_ESP_WIFI_REMOTE_ENABLED=y
CONFIG_ESP_WIFI_REMOTE_LIBRARY_HOSTED=y

# HTTPS certificate bundle
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_CMN=y

# Flash size (actual hardware is 16MB)
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y

# Partition table: custom large factory (firmware ~4MB)
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_LV_FONT_SIMSUN_14_CJK=y
CONFIG_LV_FONT_FMT_TXT_LARGE=y
CONFIG_LV_FONT_DEFAULT_SIMSUN_14_CJK=y

# SC2336 camera sensor driver
CONFIG_CAMERA_SC2336=y
CONFIG_CAMERA_SC2336_MIPI_RAW8_1024X600_30FPS=y

